{
  "constraints": [
    ".isComplete('result')",
    ".isContainedIn('result', ['runs', 'wickets'])",
    ".satisfies(\"coalesce((NOT ((toss_decision = 'bat') AND (winner = toss_winner))) OR (result = 'runs'), true)\", \"result_runs_when_bat_and_winner_is_tosswinner\")",
    ".satisfies(\"coalesce((NOT ((toss_decision = 'field') AND (winner != toss_winner))) OR (result = 'runs'), true)\", \"result_runs_when_field_and_winner_is_not_tosswinner\")",
    ".satisfies(\"coalesce((NOT ((toss_decision = 'field') AND (winner = toss_winner))) OR (result = 'wickets'), true)\", \"result_wickets_when_field_and_winner_is_tosswinner\")",
    ".satisfies(\"coalesce((NOT ((toss_decision = 'bat') AND (winner != toss_winner))) OR (result = 'wickets'), true)\", \"result_wickets_when_bat_and_winner_is_not_tosswinner\")"
  ]
}

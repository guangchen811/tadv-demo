# TaDV Demo - Frontend Configuration
# This file contains shared, non-sensitive configuration values
# All variables must be prefixed with VITE_ to be accessible in the app

# =============================================================================
# API Configuration
# =============================================================================

# Backend API base URL
# Development: http://localhost:8000
# Production: Update to your deployed backend URL
VITE_API_BASE_URL=http://localhost:8000

# Use mock API instead of real backend
# Set to 'true' to use mock data (no backend required)
# Set to 'false' to connect to real backend API
VITE_USE_MOCK_API=false

# =============================================================================
# Feature Flags
# =============================================================================

# Enable flow graph visualization in bottom panel
VITE_ENABLE_FLOW_GRAPH=true

# Enable debug mode (shows additional logging)
VITE_ENABLE_DEBUG=false

# =============================================================================
# App Metadata
# =============================================================================

# Application name (displayed in UI)
VITE_APP_NAME=TaDV

# Application version
VITE_APP_VERSION=0.10.0

# =============================================================================
# Security
# =============================================================================

# Require password to use shared API key
# Set to 'true' to enable password protection
VITE_REQUIRE_PASSWORD=false
